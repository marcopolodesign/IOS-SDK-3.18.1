# Supabase Configuration
# These override the production defaults in SupabaseService.ts (for local dev with local Supabase)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Strava OAuth Configuration
STRAVA_CLIENT_ID=192408
STRAVA_CLIENT_SECRET=your-client-secret-here

# Optional: For development with existing tokens
STRAVA_ACCESS_TOKEN=
STRAVA_REFRESH_TOKEN=
